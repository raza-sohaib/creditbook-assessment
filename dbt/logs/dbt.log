[0m13:20:42.527520 [debug] [Thread-1 (]: On model.creditbook_assessment.mart_loan_performance: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "creditbook_assessment", "target_name": "dev", "node_id": "model.creditbook_assessment.mart_loan_performance"} */

      
  
    

  create  table "creditbook"."marts"."mart_loan_performance"
  
  
    as
  
  (
    

WITH  __dbt__cte__stg_fact_transactions as (


select * from "creditbook"."staging"."fact_transactions"
),  __dbt__cte__stg_dim_risks as (


select * from "creditbook"."staging"."dim_risks"
),  __dbt__cte__stg_services_latest as (


select * from "creditbook"."staging"."services_latest"
),  __dbt__cte__stg_service_terms_latest as (


select * from "creditbook"."staging"."service_terms_latest"
),  __dbt__cte__stg_dim_entities as (


select * from "creditbook"."staging"."dim_entities"
),  __dbt__cte__stg_dim_partners as (


select * from "creditbook"."staging"."dim_partners"
), last_transaction AS (
	SELECT service_id,
	       transaction_date,
	       total_pending_amount
	FROM (
	    SELECT service_id, transaction_date, transaction_order, total_pending_amount,
	           ROW_NUMBER() OVER (
	               PARTITION BY service_id
	               ORDER BY transaction_order DESC
	           ) AS rn
	    FROM __dbt__cte__stg_fact_transactions
        
	) t
	WHERE rn = 1
),

risk AS (
    SELECT
        entity_id,
        financier_id,
        product_id,
        credit_rating,
        probability_of_default
    FROM (
        SELECT
            *,
            ROW_NUMBER() OVER (
                PARTITION BY entity_id, financier_id, product_id
                ORDER BY updated_at DESC
            ) AS rn
        FROM __dbt__cte__stg_dim_risks
    ) t
    WHERE rn = 1
),

loan_performance AS (
	SELECT 
		sl.service_id,
		sl.entity_id,
		sl.partner_id,
		sl.financier_id,
		sl.type,
		sl.entity_type,
		sl.current_status,
		sl.requested_amount,
		sl.currency_code,
		de.business_name,
		de.full_name,
		dp.partner_name,
		dr.credit_rating,
		lt.transaction_date,
		lt.total_pending_amount,
		stl.tenor,
		CASE
	        WHEN COALESCE(lt.total_pending_amount, 0) > 0
	            THEN current_date - lt.transaction_date::date
	        ELSE 0
	    END AS dpd_days,
	    (current_date - stl.disbursement_date::date) as elapsed_days,
	    stl.markup * (1 - dr.probability_of_default) as risk_adjusted_return
	FROM __dbt__cte__stg_services_latest sl
	JOIN last_transaction lt
		ON sl.service_id = lt.service_id
	LEFT JOIN __dbt__cte__stg_service_terms_latest stl 
		ON sl.service_id = stl.service_id 
	LEFT JOIN __dbt__cte__stg_dim_entities de 
		ON sl.entity_id = de.entity_id AND de.valid_to >= '9999-12-31'
	LEFT JOIN __dbt__cte__stg_dim_partners dp
		ON sl.partner_id = dp.partner_id AND dp.valid_to >= '9999-12-31'
	LEFT JOIN risk dr
		ON sl.entity_id  = dr.entity_id  AND sl.financier_id  = dr.financier_id  AND sl.product_id = dr.product_id 
)

SELECT 
    service_id,
	entity_id,
	partner_id,
	financier_id,
    type,
    business_name,
    full_name,
    entity_type,
    partner_name,
    credit_rating,
    requested_amount,
    currency_code,
    current_status,
    total_pending_amount,
    risk_adjusted_return,
	dpd_days AS dpd,
    CASE
        WHEN dpd_days = 0 THEN '0 Days'
        WHEN dpd_days BETWEEN 1 AND 30 THEN '1-30 Days'
        WHEN dpd_days BETWEEN 31 AND 60 THEN '31-60 Days'
        WHEN dpd_days BETWEEN 61 AND 90 THEN '61-90 Days'
        ELSE '90+ Days'
    END AS dpd_bucket,
    CASE
        WHEN nullif(tenor, 0) IS NOT NULL
             AND (elapsed_days::NUMERIC / nullif(tenor * 365, 0)) < 0.25
             AND dpd_days > 7
        THEN true
        ELSE false
    END AS early_default_risk
FROM loan_performance
  );
  
  
