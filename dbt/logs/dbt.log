  create  table "creditbook"."analytics_marts"."mart_loan_performance"
  
  
    as
  
  (
    

with services as (
    select *
    from "creditbook"."analytics_staging"."stg_services_latest"
    
),
terms as (
    select * from "creditbook"."analytics_staging"."stg_service_terms_latest"
),
entities as (
    select
        entity_id,
        full_name as borrower_name_encrypted,
        business_name as business_name_encrypted,
        updated_at as entity_updated_at
    from "creditbook"."analytics_staging"."stg_dim_entities"
),
partners as (
    select partner_id, partner_name, status as partner_status
    from "creditbook"."analytics_staging"."stg_dim_partners"
),
financiers as (
    select distinct financier_id, financier_name
    from "creditbook"."analytics_staging"."stg_dim_financiers"
),
entity_products as (
    select entity_product_id, risk_id
    from "creditbook"."analytics_staging"."stg_dim_entity_products"
),
risks as (
    select
        risk_id,
        credit_rating,
        probability_of_default
    from "creditbook"."analytics_staging"."stg_dim_risks"
),
oldest_unpaid as (
    select
        service_id,
        min(transaction_date::date) filter (where coalesce(total_pending_amount, 0) > 0) as oldest_unpaid_due_date
    from "creditbook"."analytics_staging"."stg_fact_transactions"
    group by 1
),
joined as (
    select
        s.service_id,
        s.entity_id,
        s.entity_product_id,
        s.partner_id,
        s.financier_id,
        s.current_status,
        s.updated_at as source_updated_at,
        -- replace decrypt_pii(...) with the actual available UDF in your warehouse if needed
        coalesce(e.business_name_encrypted, e.borrower_name_encrypted) as borrower_name,
        p.partner_name,
        p.partner_status,
        f.financier_name,
        r.credit_rating,
        r.probability_of_default as pd,
        t.principal,
        t.markup,
        t.tenor,
        t.disbursement_date,
        t.due_date,
        o.oldest_unpaid_due_date,
        case
            when o.oldest_unpaid_due_date is null then 0
            else greatest((current_date - o.oldest_unpaid_due_date), 0)
        end as dpd,
        (t.markup * (1 - coalesce(r.probability_of_default, 0))) as risk_adjusted_return,
        case
            when coalesce(t.tenor, 0) > 0
             and t.disbursement_date is not null
             and ((current_date - t.disbursement_date::date)::numeric / t.tenor::numeric) < 0.25
             and case
                    when o.oldest_unpaid_due_date is null then 0
                    else greatest((current_date - o.oldest_unpaid_due_date), 0)
                 end > 7
            then true else false
        end as early_default_risk
    from services s
    left join terms t on s.service_id = t.service_id
    left join entities e on s.entity_id = e.entity_id
    left join partners p on s.partner_id = p.partner_id
    left join financiers f on s.financier_id = f.financier_id
    left join entity_products ep on s.entity_product_id = ep.entity_product_id
    left join risks r on ep.risk_id = r.risk_id
    left join oldest_unpaid o on s.service_id = o.service_id
)

select
    *,
    case
        when dpd = 0 then '0 days'
        when dpd between 1 and 30 then '1-30 days'
        when dpd between 31 and 60 then '31-60 days'
        when dpd between 61 and 90 then '61-90 days'
        else '90+ days'
    end as dpd_bucket
from joined
  );
  
  
